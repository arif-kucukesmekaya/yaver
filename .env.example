# ==========================================
# SellerAI Backend - Environment Variables
# ==========================================
# Copy this file to .env and fill in your values

# ==========================================
# APPLICATION
# ==========================================
NODE_ENV=development
PORT=8881

# ==========================================
# DATABASE
# ==========================================
DATABASE_URL=postgresql://sellerai_user:sellerai_pass@localhost:5432/sellerai_db

# ==========================================
# JWT AUTHENTICATION
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
JWT_EXPIRES_IN=7d

# ==========================================
# OPENAI API
# ==========================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1

# ==========================================
# GEMINI API (Optional - for future use)
# ==========================================
# GEMINI_API_KEY=your-gemini-api-key-here

# ==========================================
# FILE UPLOAD
# ==========================================
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# ==========================================
# CORS (Optional - defaults set in code)
# ==========================================
# CORS_ORIGIN=http://localhost:3000

# ==========================================
# RATE LIMITING (Optional - defaults in code)
# ==========================================
# RATE_LIMIT_WINDOW=900000
# RATE_LIMIT_MAX=100

# ==========================================
# EXTERNAL SERVICES (Future use)
# ==========================================
# STRIPE_SECRET_KEY=sk_test_your_stripe_key
# SENDGRID_API_KEY=SG.your_sendgrid_key
# AWS_S3_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
